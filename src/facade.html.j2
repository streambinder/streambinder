<!doctype html>
<html lang="en">

<head>

    <!-- title -->
    <title>{{ html.head.title }}</title>
    <meta name="description" content="{{ html.head.metadata.description }}" />
    <link rel="canonical" href="{{ html.head.metadata.url }}" />
    {! if page.noindex !}
    <meta name="robots" content="noindex" />
    {! endif !}

    <!-- Google meta tags -->
    <meta name="google" content="nositelinkssearchbox" />

    <!-- Facebook meta tags -->
    <meta property="og:url" content="{{ html.head.metadata.url }}" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="{{ html.head.metadata.title }}" />
    <meta property="og:description" content="{{ html.head.metadata.description }}" />

    <!-- Twitter meta tags -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="{{ html.head.metadata.title }}" />
    <meta name="twitter:description" content="{{ html.head.metadata.description }}" />
    <meta property="twitter:url" content="{{ html.head.metadata.url }}" />
    <meta property="twitter:domain" content="davidepucci.it" />

    <!-- structured data -->
    {! if html.head.jsonld !}
    <script type="application/ld+json">
    {{ html.head.jsonld }}
    </script>
    {! endif !}

    <!-- view -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- browser chrome tint; keep in sync with --bg in css/main-var.css -->
    <meta name="theme-color" content="#0c0c0f" />

    <!-- fonts (Google Fonts preconnect for faster first paint) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- styles -->
    <link rel="stylesheet" href="/css/main.css" />

    <!-- favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

</head>

<body class="{{ page.path[1:] | replace('/', '-') }}">
    <nav role="navigation" aria-label="Main">
        <a href="/" class="nav-brand" aria-label="Home">davide pucci</a>
        <span class="nav-links">
            <a href="/sig/" aria-label="PGP public key"{! if page.path.startswith('/sig') !} class="active"{! endif !}>pgp</a>
            <span class="nav-sep">·</span>
            <a href="/doc/" aria-label="Projects documentation"{! if page.path.startswith('/doc') !} class="active"{! endif !}>docs</a>
            <span class="nav-sep">·</span>
            <a href="/resume/"{! if page.path.startswith('/resume') !} class="active"{! endif !}>resume</a>
        </span>
    </nav>

    {{ html.body }}

    <footer role="contentinfo">
        <span>davide pucci</span>
        <span class="footer-social">
            {! for entry in info.social if entry.name not in ['Resume', 'PGP'] !}
            <a href="{{ entry.url }}" aria-label="{{ entry.name }}">{{ entry.name | lower }}</a>
            {! endfor !}
        </span>
    </footer>
</body>

</html>
