<main class="page">
  <h1>{{ page.name }}</h1>
  <ul class="cards">
    {! for entry in pages|selectattr("type", "in", "doc,wiki")|selectattr("alive") !}
    <li>
      <a href="/doc/{{ entry.name.lower() }}">
        <span>{{ entry.name }}</span>
        <p class="caption">{{ entry.caption }}</p>
      </a>
    </li>
    {! endfor !}
  </ul>

  <h2>Archived</h2>
  <ul class="cards">
    {! for entry in pages|selectattr("type", "in", "doc,wiki")|rejectattr("alive") !}
    <li>
      <a href="/doc/{{ entry.name.lower() }}">
        <span>{{ entry.name }}</span>
        <p class="caption">{{ entry.caption }}</p>
      </a>
    </li>
    {! endfor !}
  </ul>
</main>
