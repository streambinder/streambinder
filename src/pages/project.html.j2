<main class="page">
  <h1>
    <a href="{{ page.url }}">{{ page.name }}</a>
  </h1>
  <h5 class="caption">{{ page.caption }}</h5>

  {! if not page.alive !}
  <div class="disclaimer">
    <h5>
      This project is no more under active development.<br />
      This may affect its usage in unpredictable and unguaranteed ways.
    </h5>
  </div>
  {! endif !}

  <ul class="cards">
    {! if page.url !}
    <li>
      <a href="{{ page.url }}" target="_blank" rel="noopener">
        <span>GitHub</span>
      </a>
    </li>
    {! endif !}
    {! for section in page.sections !}
    <li>
      <a href="#{{ section.id }}">
        <span>{{ section.name }}</span>
      </a>
    </li>
    {! endfor !}
  </ul>

  <span class="separator"></span>

  {{ page.content }}
</main>
