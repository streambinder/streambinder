<main class="page">
  <h1 class="sr-only">{{ page.name }}</h1>
  <h2>Download</h2>
  {! set groups = {} !}
  {! for resume in page.variants !}
  {! set _ = groups.setdefault(resume.name.split(' ')[0], []).append(resume) !}
  {! endfor !}
  <ul>
    {! for kind, variants in groups.items() !}
    <li>{{ kind }}: {! for resume in variants !}<a href="{{ resume.url }}">{{ resume.name.split(' ')[1] }}</a>{! if not loop.last !} · {! endif !}{! endfor !}</li>
    {! endfor !}
  </ul>

  {{ prefetch }}
</main>
